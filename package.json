{
  "name": "rusniped",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@rusniped/web",
    "build": "npm run build --workspace=@rusniped/web",
    "typecheck": "tsc --noEmit -p apps/web && tsc --noEmit -p packages/shared"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}